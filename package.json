{
  "name": "x402ton-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/ton",
    "server"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "eslint .",
    "format": "prettier --write \"packages/ton/src/**/*.ts\" \"server/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/ton/src/**/*.ts\" \"server/src/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
