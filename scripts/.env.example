# E2E test configuration
# Copy to .env and fill in values, or export as env vars

# Required: 24-word mnemonic of a funded client wallet
CLIENT_MNEMONIC="word1 word2 ... word24"

# Required: raw address of the vendor (payment recipient)
VENDOR_ADDRESS="0:..."

# Optional: facilitator URL (default: https://x402.resistance.dog)
FACILITATOR_URL="https://x402.resistance.dog"

# Optional: Toncenter API key (for higher rate limits)
TONCENTER_API_KEY=""

# Required for USDT gasless test: TONAPI key
TONAPI_KEY=""
